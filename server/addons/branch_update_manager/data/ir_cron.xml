<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron: Verificar actualizaciones (para sucursales) -->
        <record id="cron_check_updates" model="ir.cron">
            <field name="name">Branch Update: Check for Updates</field>
            <field name="model_id" ref="model_branch_update_agent"/>
            <field name="state">code</field>
            <field name="code">model.check_for_updates()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="priority">5</field>
        </record>

        <!-- Cron: Limpiar logs antiguos -->
        <record id="cron_cleanup_logs" model="ir.cron">
            <field name="name">Branch Update: Cleanup Old Logs</field>
            <field name="model_id" ref="model_branch_update_log"/>
            <field name="state">code</field>
            <field name="code">model.cleanup_old_logs(days=90)</field>
            <field name="interval_number">1</field>
            <field name="interval_type">weeks</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="priority">100</field>
        </record>

        <!-- Cron: Verificar sucursales offline -->
        <record id="cron_check_offline_branches" model="ir.cron">
            <field name="name">Branch Update: Check Offline Branches</field>
            <field name="model_id" ref="model_branch_registry"/>
            <field name="state">code</field>
            <field name="code">
# Buscar sucursales que no se han conectado en 24 horas
from datetime import datetime, timedelta
threshold = datetime.now() - timedelta(hours=24)
branches = model.search([
    ('state', '=', 'active'),
    ('last_connection', '&lt;', threshold),
])
if branches:
    # Enviar notificación al administrador
    env['mail.mail'].sudo().create({
        'subject': f'[ALERTA] {len(branches)} sucursales offline',
        'body_html': f'Las siguientes sucursales no se han conectado en 24 horas: {", ".join(branches.mapped("name"))}',
        'email_to': env['ir.config_parameter'].sudo().get_param('branch_update.admin_email', 'admin@example.com'),
    }).send()
            </field>
            <field name="interval_number">6</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="priority">50</field>
        </record>

        <!-- Cron: Deprecar paquetes expirados -->
        <record id="cron_deprecate_expired" model="ir.cron">
            <field name="name">Branch Update: Deprecate Expired Packages</field>
            <field name="model_id" ref="model_branch_update_package"/>
            <field name="state">code</field>
            <field name="code">
from datetime import date
expired = model.search([
    ('state', '=', 'published'),
    ('expiry_date', '&lt;', date.today()),
])
expired.write({'state': 'deprecated'})
            </field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="priority">100</field>
        </record>

    </data>
</odoo>
