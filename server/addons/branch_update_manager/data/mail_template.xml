<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Plantilla: Notificación de nuevo paquete -->
        <record id="mail_template_new_package" model="mail.template">
            <field name="name">Branch Update: New Package Available</field>
            <field name="model_id" ref="model_branch_update_package"/>
            <field name="subject">Nuevo paquete de actualización disponible: {{ object.reference }}</field>
            <field name="email_from">{{ (object.company_id.email or user.email_formatted) }}</field>
            <field name="body_html" type="html">
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
    <h2 style="color: #875A7B;">Nuevo Paquete de Actualización</h2>

    <table style="width: 100%; border-collapse: collapse;">
        <tr>
            <td style="padding: 8px; border-bottom: 1px solid #ddd;"><strong>Referencia:</strong></td>
            <td style="padding: 8px; border-bottom: 1px solid #ddd;">{{ object.reference }}</td>
        </tr>
        <tr>
            <td style="padding: 8px; border-bottom: 1px solid #ddd;"><strong>Nombre:</strong></td>
            <td style="padding: 8px; border-bottom: 1px solid #ddd;">{{ object.name }}</td>
        </tr>
        <tr>
            <td style="padding: 8px; border-bottom: 1px solid #ddd;"><strong>Versión:</strong></td>
            <td style="padding: 8px; border-bottom: 1px solid #ddd;">{{ object.version }}</td>
        </tr>
        <tr>
            <td style="padding: 8px; border-bottom: 1px solid #ddd;"><strong>Tipo:</strong></td>
            <td style="padding: 8px; border-bottom: 1px solid #ddd;">{{ object.update_type }}</td>
        </tr>
        <tr>
            <td style="padding: 8px; border-bottom: 1px solid #ddd;"><strong>Prioridad:</strong></td>
            <td style="padding: 8px; border-bottom: 1px solid #ddd;">{{ object.priority }}</td>
        </tr>
        <tr>
            <td style="padding: 8px; border-bottom: 1px solid #ddd;"><strong>Tamaño:</strong></td>
            <td style="padding: 8px; border-bottom: 1px solid #ddd;">{{ object.package_size_display }}</td>
        </tr>
    </table>

    <h3 style="color: #875A7B; margin-top: 20px;">Descripción</h3>
    <p>{{ object.description or 'Sin descripción' }}</p>

    <h3 style="color: #875A7B; margin-top: 20px;">Notas de la Versión</h3>
    <div>{{ object.release_notes or 'Sin notas de versión' }}</div>

    <hr style="margin: 20px 0;"/>
    <p style="color: #888; font-size: 12px;">
        Este es un mensaje automático del Sistema de Actualización de Sucursales.
    </p>
</div>
            </field>
            <field name="auto_delete" eval="False"/>
        </record>

        <!-- Plantilla: Actualización exitosa -->
        <record id="mail_template_update_success" model="mail.template">
            <field name="name">Branch Update: Update Successful</field>
            <field name="model_id" ref="model_branch_update_log"/>
            <field name="subject">✓ Actualización exitosa: {{ object.branch_id.name }}</field>
            <field name="body_html" type="html">
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
    <h2 style="color: #28a745;">Actualización Exitosa</h2>

    <p>La sucursal <strong>{{ object.branch_id.name }}</strong> ha sido actualizada correctamente.</p>

    <table style="width: 100%; border-collapse: collapse;">
        <tr>
            <td style="padding: 8px; border-bottom: 1px solid #ddd;"><strong>Paquete:</strong></td>
            <td style="padding: 8px; border-bottom: 1px solid #ddd;">{{ object.package_id.reference }}</td>
        </tr>
        <tr>
            <td style="padding: 8px; border-bottom: 1px solid #ddd;"><strong>Versión:</strong></td>
            <td style="padding: 8px; border-bottom: 1px solid #ddd;">{{ object.package_id.version }}</td>
        </tr>
        <tr>
            <td style="padding: 8px; border-bottom: 1px solid #ddd;"><strong>Duración:</strong></td>
            <td style="padding: 8px; border-bottom: 1px solid #ddd;">{{ object.duration }} segundos</td>
        </tr>
    </table>
</div>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>

        <!-- Plantilla: Actualización fallida -->
        <record id="mail_template_update_failed" model="mail.template">
            <field name="name">Branch Update: Update Failed</field>
            <field name="model_id" ref="model_branch_update_log"/>
            <field name="subject">✗ Actualización fallida: {{ object.branch_id.name }}</field>
            <field name="body_html" type="html">
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
    <h2 style="color: #dc3545;">Actualización Fallida</h2>

    <p>La actualización de la sucursal <strong>{{ object.branch_id.name }}</strong> ha fallado.</p>

    <table style="width: 100%; border-collapse: collapse;">
        <tr>
            <td style="padding: 8px; border-bottom: 1px solid #ddd;"><strong>Paquete:</strong></td>
            <td style="padding: 8px; border-bottom: 1px solid #ddd;">{{ object.package_id.reference }}</td>
        </tr>
        <tr>
            <td style="padding: 8px; border-bottom: 1px solid #ddd;"><strong>Error:</strong></td>
            <td style="padding: 8px; border-bottom: 1px solid #ddd; color: #dc3545;">{{ object.error_message }}</td>
        </tr>
        <tr>
            <td style="padding: 8px; border-bottom: 1px solid #ddd;"><strong>Reintentos:</strong></td>
            <td style="padding: 8px; border-bottom: 1px solid #ddd;">{{ object.retry_count }} / {{ object.max_retries }}</td>
        </tr>
    </table>

    <p style="margin-top: 20px;">
        <strong>Acción requerida:</strong> Por favor revise el log de errores y tome las acciones necesarias.
    </p>
</div>
            </field>
            <field name="auto_delete" eval="False"/>
        </record>

    </data>
</odoo>
